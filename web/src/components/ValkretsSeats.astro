---
import valkrets from '../data/valkrets.json';
import forecast from '../data/forecast.json';

// Party colour + Swedish name from the forecast payload.
const meta = Object.fromEntries(forecast.parties.map((p) => [p.code, p]));
const SPECTRUM = ['V', 'S', 'MP', 'C', 'L', 'KD', 'M', 'SD']; // left → right

// Valkrets sorted by size (biggest first); precompute the spectrum-ordered segments.
const rows = [...valkrets.valkrets]
  .sort((a, b) => b.seats - a.seats)
  .map((v) => ({
    ...v,
    segs: SPECTRUM.filter((c) => (v.parties[c] ?? 0) > 0)
      .map((c) => ({ code: c, n: v.parties[c], color: meta[c]?.color ?? '#999' })),
  }));

const totals = valkrets.party_totals; // = the central parliament (matches the hemicycle)
const totalSeats = rows.reduce((a, v) => a + v.seats, 0);
const totalSpectrum = SPECTRUM.filter((c) => (totals[c] ?? 0) > 0);
---
<section class="vk">
  <div class="vk-totals">
    <p class="vk-label">Centrala prognosen — {totalSeats} mandat</p>
    <div class="vk-bar" role="img" aria-label="Mandat per parti i hela riket">
      {totalSpectrum.map((c) => (
        <span class="seg" style={`flex:${totals[c]};background:${meta[c]?.color}`} title={`${meta[c]?.name}: ${totals[c]}`}></span>
      ))}
    </div>
    <ul class="vk-legend">
      {totalSpectrum.map((c) => (
        <li><span class="sw" style={`background:${meta[c]?.color}`}></span>{c} {totals[c]}</li>
      ))}
    </ul>
  </div>

  <ol class="vk-list">
    {rows.map((v) => (
      <li class="vk-row">
        <div class="vk-name">{v.name.replace(' valkrets', '')}<span class="vk-seats">{v.seats}</span></div>
        <div class="vk-bar small">
          {v.segs.map((s) => (
            <span class="seg" style={`flex:${s.n};background:${s.color}`} title={`${meta[s.code]?.name}: ${s.n}`}></span>
          ))}
        </div>
        <div class="vk-nums">{v.segs.map((s) => (<span class="num" style={`color:${s.color}`}>{s.code}&nbsp;{s.n}</span>))}</div>
      </li>
    ))}
  </ol>

  <style>
    .vk { margin: 8px 0 4px; }
    .vk-totals { margin-bottom: 18px; }
    .vk-label { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); margin: 0 0 6px; }
    .vk-bar { display: flex; height: 22px; border-radius: 5px; overflow: hidden; gap: 1px; background: var(--grid); }
    .vk-bar.small { height: 14px; }
    .vk-bar .seg { display: block; }
    .vk-legend { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; padding: 0; margin: 8px 0 0; font-size: 13px; font-weight: 700; }
    .vk-legend li { display: inline-flex; align-items: center; gap: 5px; }
    .sw { width: 11px; height: 11px; border-radius: 2px; display: inline-block; }
    .vk-list { list-style: none; padding: 0; margin: 0; }
    .vk-row { padding: 9px 0; border-top: 1px solid var(--grid); }
    .vk-name { font-size: 14px; font-weight: 700; display: flex; justify-content: space-between; margin-bottom: 4px; }
    .vk-seats { color: var(--muted); }
    .vk-nums { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; font-size: 12px; font-weight: 700; }
    .vk-nums .num { white-space: nowrap; }
  </style>
</section>
